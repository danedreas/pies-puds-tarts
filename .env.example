# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact form (Resend) - required for contact form
RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@piespudstarts.co.uk
CONTACT_FROM_EMAIL="Pies, Puds & Tarts <onboarding@resend.dev>"

# Rate limiting (optional - uses in-memory fallback when unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Pricing module - shown by default; set false to hide product cards
# NEXT_PUBLIC_SHOW_PRICING=false

# Stripe Checkout (optional - pricing cards show in demo mode without this)
NEXT_PUBLIC_ENABLE_STRIPE=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin content editor (Vercel Blob + password)
# When Blob is connected to the project, Vercel adds BLOB_STORE_ID (and VERCEL_OIDC_TOKEN on deploy).
# BLOB_WEBHOOK_PUBLIC_KEY is only needed for presigned browser uploads — not used by this admin.
ADMIN_PASSWORD=
BLOB_STORE_ID=
# Optional legacy token for environments outside Vercel:
# BLOB_READ_WRITE_TOKEN=

# Google Sheets (optional legacy - not used when Blob admin is enabled)
NEXT_PUBLIC_ENABLE_GOOGLE_SHEETS=false
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_PRODUCTS_RANGE=Products!A2:F
GOOGLE_SHEETS_EVENTS_RANGE=Events!A2:G

# Cookie consent - on by default; set false to disable
# NEXT_PUBLIC_ENABLE_COOKIE_CONSENT=false

# Google Tag Manager (optional - loads after analytics consent)
NEXT_PUBLIC_ENABLE_GTM=false
NEXT_PUBLIC_GTM_ID=

# Full legal page suite (privacy + cookies ship by default)
NEXT_PUBLIC_ENABLE_FULL_LEGAL=false
