# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact form (Resend) - required for contact form
RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@example.com
CONTACT_FROM_EMAIL="Example Business <onboarding@resend.dev>"

# Rate limiting (optional - uses in-memory fallback when unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Pricing module - shown by default; set false to hide product cards
# NEXT_PUBLIC_SHOW_PRICING=false

# Stripe Checkout (optional - pricing cards show in demo mode without this)
NEXT_PUBLIC_ENABLE_STRIPE=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STANDARD=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx

# Cookie consent - on by default; set false to disable
# NEXT_PUBLIC_ENABLE_COOKIE_CONSENT=false

# Google Tag Manager (optional - loads after analytics consent)
NEXT_PUBLIC_ENABLE_GTM=false
NEXT_PUBLIC_GTM_ID=

# Full legal page suite (privacy + cookies ship by default)
NEXT_PUBLIC_ENABLE_FULL_LEGAL=false
